# ── SwiftDocs Environment Variables ──────────────────────────────────────────
# Copy this to .env and fill in the values

# REQUIRED — generate with: openssl rand -hex 32
SECRET_KEY=change-me-min-32-chars-use-openssl-rand-hex-32

# Stripe — get from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# AWS S3 — for storing generated PDFs
# Create a bucket + IAM user with s3:PutObject on the bucket
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=...
AWS_BUCKET_NAME=swiftdocs-outputs
AWS_REGION=us-east-1

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000/api

# ── Optional overrides ────────────────────────────────────────────────────────
# DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost/swiftdocs
# REDIS_URL=redis://localhost:6379
